# Copy this file to .env in the same directory for real usage.
# Do not commit the real .env file.

HERMES_EMAIL_ACCOUNTS_JSON='[
  {
    "label": "primary",
    "email": "your-email@example.com",
    "host": "imap.example.com",
    "port": 993,
    "folder": "INBOX",
    "password_env": "HERMES_EMAIL_PRIMARY_APP_PASSWORD"
  },
  {
    "label": "provider-needing-id",
    "email": "your-second-email@example.com",
    "host": "imap.second-provider.com",
    "port": 993,
    "folder": "INBOX",
    "password_env": "HERMES_EMAIL_SECONDARY_APP_PASSWORD",
    "imap_id_workaround": true,
    "imap_id_name": "IMAPClient",
    "imap_id_version": "2.1.0",
    "imap_id_vendor": "Hermes",
    "imap_id_contact": "your-second-email@example.com"
  }
]'

HERMES_EMAIL_PRIMARY_APP_PASSWORD=replace-me
HERMES_EMAIL_SECONDARY_APP_PASSWORD=replace-me
